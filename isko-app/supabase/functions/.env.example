# Copy this file to supabase/functions/.env for local Edge Function development.
# This file is safe to commit because it contains placeholders only.
# The app resolves the upstream provider from each enabled chat model.
# AI_PROVIDER remains a legacy fallback only when the chat model registry is unavailable.

AI_PROVIDER=huggingface-router
AI_BASE_URL=https://router.huggingface.co/v1
HF_TOKEN=replace-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=replace-me
AI_SYSTEM_PROMPT=You are IskoAI. Keep answers concise, practical, and direct.
