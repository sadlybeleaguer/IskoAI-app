VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Supported fallback names:
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-only AI settings belong in supabase/functions/.env
# Copy supabase/functions/.env.example to supabase/functions/.env for local development.
# Never expose HF_TOKEN or AI_API_KEY as a VITE_ variable.
